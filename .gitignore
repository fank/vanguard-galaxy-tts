# Build
bin/
obj/
*.user
*.suo
.vs/

# Game DLL reference (user-specific absolute path, do not commit)
VGTTS/lib/*.dll
VGTTS/lib/*.pdb
!VGTTS/lib/.gitkeep

# Cache / generated TTS
cache/
*.wav
*.ogg
*.mp3

# Pre-render output (shipped as GitHub release asset, not in git)
/prerender/

# OS
.DS_Store
Thumbs.db

# Bundled TTS tools — large binaries, re-downloadable via `make download-*`
tools/
# ...but DO track the Python pre-render pipeline under tools/
!tools/prerender/
# Within the pipeline dir, exclude only data/cache subdirs
tools/prerender/variants/
tools/prerender/references/
tools/prerender/echo_tips.json
**/__pycache__/
