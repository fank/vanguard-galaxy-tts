# Build
bin/
obj/
*.user
*.suo
.vs/

# Game DLL reference (user-specific absolute path, do not commit)
VGTTS/lib/*.dll
VGTTS/lib/*.pdb
!VGTTS/lib/.gitkeep

# Legacy runtime TTS caches (plugin uses BepInEx/cache/VGTTS at runtime)
cache/
*.wav
*.mp3

# Pre-render artifacts
# Track: prerender/<speaker>/*.ogg and manifest.json (small pack, shipped in repo)
# Skip: shootout/review intermediates and debug WAV variants
prerender/shootout/
prerender/review_report.*
prerender/spot_check.md
prerender/variants/

# OS
.DS_Store
Thumbs.db

# Bundled TTS tools — large binaries, re-downloadable via `make download-*`
# List specific subdirs (can't un-ignore under a wholly-excluded parent in git)
tools/piper/
tools/sherpa/
tools/kokoro/
tools/voices/

# Within the pipeline dir, exclude only data/cache subdirs
tools/prerender/variants/
tools/prerender/accent_probes/
tools/prerender/echo_tips.json
# Build-time intermediates — regenerated by resolve_speakers.py
tools/prerender/render_plan.json
tools/prerender/resolved_lines.json
**/__pycache__/

# Track reference WAVs (needed for reproducible renders across machines)
# Must explicitly un-ignore both dir + contents since *.wav matches files
!tools/prerender/references/
!tools/prerender/references/*.wav
.claude/
dist/
